{
  "manifest_version": 3,
  "name": "Crypto Price Tracker",
  "version": "2.0",
  "description": "Theo dõi giá nhiều coin đồng thời theo cặp tuỳ chọn.",
  "permissions": [
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "https://fapi.binance.com/*",
    "https://api.binance.com/*",
    "https://www.okx.com/*",
    "https://api.bitget.com/*",
    "https://api.coingecko.com/*",
    "https://coin-images.coingecko.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "popup.js",
        "style.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' data: https://coin-images.coingecko.com;"
  }
}